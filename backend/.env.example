PORT=8080
CORS_ORIGINS=http://localhost:5173

# AI Service Configuration
# FastAPI/Google ADK service URL. Local default is http://localhost:8081
AI_SERVICE_URL=http://localhost:8081
AI_MODEL=deepseek/deepseek-v4-pro
AI_QUICK_MODEL=deepseek/deepseek-v4-flash

# Supabase Configuration
# Get these from your Supabase project dashboard -> Settings -> API
SUPABASE_URL=your-project-url
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-server-side-secret-key

# Short link and QR tracking
# Production short domain example: https://ilvu.site
# Local dev fallback can stay as http://localhost:8080/s
SHORT_URL_BASE=http://localhost:8080/s
SHORT_SLUG_LENGTH=6
ANALYTICS_HASH_SALT=change-this-random-private-string

# Credits
# Keep true after SUPABASE_CREDIT_SYSTEM.sql and SUPABASE_CREDIT_TOPUPS.sql are applied.
CREDIT_ENFORCEMENT_ENABLED=true

# Polar billing
# Keep secrets server-side only. Never expose this to the frontend.
POLAR_ACCESS_TOKEN=your-polar-server-api-token
POLAR_WEBHOOK_SECRET=your-polar-webhook-secret
POLAR_DEFAULT_PLAN_KEY=
POLAR_STARTER_PRODUCT_IDS=
POLAR_STARTER_PRICE_IDS=
POLAR_PRO_PRODUCT_IDS=
POLAR_PRO_PRICE_IDS=
POLAR_PRO_PLUS_PRODUCT_IDS=
POLAR_PRO_PLUS_PRICE_IDS=
POLAR_TOPUP_100_CHECKOUT_URL=
POLAR_TOPUP_100_PRODUCT_IDS=
POLAR_TOPUP_100_PRICE_IDS=
POLAR_TOPUP_300_CHECKOUT_URL=
POLAR_TOPUP_300_PRODUCT_IDS=
POLAR_TOPUP_300_PRICE_IDS=
POLAR_TOPUP_1000_CHECKOUT_URL=
POLAR_TOPUP_1000_PRODUCT_IDS=
POLAR_TOPUP_1000_PRICE_IDS=

# URL guardrails. Keep false in production. Set true only for local tests against private/local URLs.
ALLOW_PRIVATE_URLS=false

# Redis Configuration (for Celery / BullMQ if needed)
REDIS_URL=redis://localhost:6379

# Firecrawl API key. Use FIRECRAWL_API_KEY in all new environments.
# FIRECRAWLER_API_KEY is accepted by code only as a legacy fallback.
FIRECRAWL_API_KEY=your-firecrawl-key

# Optional Google PageSpeed Insights API key for SEO Analyzer enrichment.
# The API can work without a key in some local tests, but production should use a key for quota stability.
PAGESPEED_API_KEY=your-pagespeed-api-key

# Optional Chrome UX Report API key. If omitted, the SEO Analyzer reuses PAGESPEED_API_KEY.
CRUX_API_KEY=your-crux-api-key

# Optional local/production Presenton renderer for URL to Presentation PPTX export.
# Local Docker default: http://localhost:5000
PRESENTON_ENABLED=false
PRESENTON_API_URL=http://localhost:5000
PRESENTON_TEMPLATE=swift

# Optional SocialKit API for URL to Transcribe.
# Supports YouTube, Facebook, Instagram, and TikTok transcript extraction.
SOCIALKIT_API_KEY=your-socialkit-access-key
SOCIALKIT_API_URL=https://api.socialkit.dev
